# Copy this file to .env.local and fill in the values.
# Never commit .env.local — it is in .gitignore.

# Supabase project URL (safe for browser)
NEXT_PUBLIC_SUPABASE_URL=

# Supabase anon/public key (safe for browser)
NEXT_PUBLIC_SUPABASE_ANON_KEY=

# Supabase service role key — server-only, never expose to browser
# Used by scripts/seed-races.ts only
SUPABASE_SERVICE_ROLE_KEY=

# Shell environment — MCP servers only, never commit
# SUPABASE_ACCESS_TOKEN=    # Supabase personal access token (for Supabase MCP)
# GITHUB_PERSONAL_ACCESS_TOKEN=  # GitHub PAT (for GitHub MCP, optional)
